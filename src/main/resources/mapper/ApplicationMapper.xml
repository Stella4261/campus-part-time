<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campus.parttime.mapper.ApplicationMapper">
    <select id="selectByStudentId" resultType="com.campus.parttime.entity.Application">
        select * from application where student_id=#{studentId}
    </select>
    <select id="selectByJobId" resultType="com.campus.parttime.entity.Application">
        select * from application where job_id=#{jobId}
    </select>
    <insert id="insertApplication">
        insert into application(job_id,student_id,cover_letter,status)
        values(#{jobId},#{studentId},#{coverLetter},#{status})
    </insert>
    <update id="updateApplication">
        update application set status=#{status} where id=#{id}
    </update>
</mapper>